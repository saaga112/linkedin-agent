# ============================================================
#  LinkedIn AI Agent — Environment Variables
#  Copy this file to .env and fill in your credentials.
#  NEVER commit your .env file to git!
# ============================================================

# ── Anthropic (Claude AI) ───────────────────────────────────
# Get your API key from: https://console.anthropic.com/
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Optionally override the Claude model (default: claude-opus-4-6)
# CLAUDE_MODEL=claude-opus-4-6

# ── LinkedIn Login (for browser-based comment/message monitoring) ──
LINKEDIN_EMAIL=agarsatyam1@gmail.com
LINKEDIN_PASSWORD=your_linkedin_password_here

# ── LinkedIn Developer App (for official API posting) ───────
# Create an app at: https://www.linkedin.com/developers/apps
# Required scopes: openid, profile, email, w_member_social
LINKEDIN_CLIENT_ID=your_linkedin_app_client_id
LINKEDIN_CLIENT_SECRET=your_linkedin_app_client_secret

# Access token (obtained by running: python main.py --setup)
# Leave blank on first run, then fill in after setup.
LINKEDIN_ACCESS_TOKEN=

# ── Posting Schedule ────────────────────────────────────────
# Day of week: monday, tuesday, wednesday, thursday, friday
POST_DAY_OF_WEEK=tuesday
# Time (24-hour format, local timezone)
POST_HOUR=9
POST_MINUTE=0

# ── Engagement (Comment & Message Replies) ──────────────────
# How often to scan for new comments/messages (in minutes)
ENGAGEMENT_INTERVAL_MINUTES=30

# ── Browser Settings ────────────────────────────────────────
# Set to "false" for first login (so you can handle 2FA manually)
# Set to "true" after session is saved, for background operation
HEADLESS_BROWSER=false

# ── Data Directory ───────────────────────────────────────────
# Where to store session files, post logs, reply state, etc.
DATA_DIR=./data

# ── Safety Mode ─────────────────────────────────────────────
# Set to "true" to generate content but NOT post or reply (great for testing)
DRY_RUN=false
